{
  "name": "setup-nuget-exe",
  "version": "4.0.0",
  "private": true,
  "description": "Download and install NuGet.exe for use in GitHub Actions.",
  "type": "module",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run build && npm run format && npm run package && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/setup-nuget.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "step-security",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/exec": "^3.0.0",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "axios": "^1.16.1",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.58.2",
    "@vercel/ncc": "^0.38.3",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.2",
    "jest": "^30.4.2",
    "jest-circus": "^30.3.0",
    "mode-to-permissions": "0.0.2",
    "nock": "^14.0.12",
    "prettier": "3.8.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  }
}
